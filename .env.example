# Supabase (optional for local mock mode)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Transcription Storage bucket (optional — defaults to voice-transcription)
EXPO_PUBLIC_TRANSCRIPTION_BUCKET=voice-transcription

# Edge Function secrets (set in Supabase dashboard / CLI — never in the Expo app)
# MISTRAL_API_KEY=
# TRANSCRIPTION_PROVIDER=mistral
# MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest
# VOICE_TRANSCRIPTION_BUCKET=voice-transcription
#
# Optional legacy OpenAI provider (TRANSCRIPTION_PROVIDER=openai):
# OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=whisper-1
